POSTGRES_DB=choir_app
POSTGRES_USER=choir_app
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

DATABASE_URL=postgresql+psycopg2://choir_app:replace-with-a-strong-postgres-password@db:5432/choir_app
UPLOAD_DIR=/app/uploads
CORS_ORIGINS=https://admin.dmajorchoir.com,https://member.dmajorchoir.com
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
AUTO_CREATE_TABLES=true
ALLOW_DEMO_LOGIN_CODE=false
AUTH_ALLOW_OPEN_REGISTRATION=true
SMS_PROVIDER=tencent
SMS_CODE_EXPIRE_SECONDS=300
SMS_RESEND_INTERVAL_SECONDS=60
SMS_MAX_VERIFY_ATTEMPTS=5
TENCENTCLOUD_SECRET_ID=replace-with-tencent-cloud-secret-id
TENCENTCLOUD_SECRET_KEY=replace-with-tencent-cloud-secret-key
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=replace-with-sms-sdk-app-id
TENCENT_SMS_SIGN_NAME=replace-with-approved-sms-sign-name
TENCENT_SMS_TEMPLATE_ID=replace-with-approved-template-id
ALLOW_LEGACY_USER_ID_TOKEN=false
ENABLE_PUBLIC_UPLOADS=false
FILE_SIGNED_URL_EXPIRE_SECONDS=600

VITE_API_BASE_URL=https://api.dmajorchoir.com
