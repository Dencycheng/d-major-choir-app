.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.stat {
  margin-bottom: 0;
  text-align: center;
}

.stat-num {
  color: #c69f62;
  font-size: 42rpx;
  font-weight: 900;
}

.note {
  margin-top: 14rpx;
}

.feedback {
  margin-top: 16rpx;
  padding: 18rpx;
  border-left: 6rpx solid #c69f62;
  border-radius: 12rpx;
  background: #fff8ea;
}

.avatar {
  display: block;
  width: 128rpx;
  height: 128rpx;
  margin-bottom: 18rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #e8d5af;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 128rpx;
  text-align: center;
}
