<view class="page">
  <view class="hero">
    <image wx:if="{{member.avatarUrl}}" class="avatar" src="{{member.avatarFullUrl}}" mode="aspectFill"></image>
    <view wx:else class="avatar placeholder">{{member.initial}}</view>
    <view class="hero-title">{{member.name}}</view>
    <view class="hero-subtitle">{{member.sectionLabel}} · {{member.role}}</view>
    <view class="btn-row">
      <button class="btn primary" bindtap="chooseAvatar">上传头像</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">我的资料</view>
    <view class="card">
      <view class="field">
        <view class="label">昵称</view>
        <input value="{{profileForm.nickname}}" data-field="nickname" bindinput="onProfileInput" />
      </view>
      <view class="field">
        <view class="label">手机号</view>
        <input value="{{profileForm.mobile}}" data-field="mobile" bindinput="onProfileInput" />
      </view>
      <view class="field">
        <view class="label">邮箱</view>
        <input value="{{profileForm.email}}" data-field="email" bindinput="onProfileInput" />
      </view>
      <view class="field">
        <view class="label">声部申请</view>
        <picker value="{{profileForm.sectionIndex}}" range="{{sectionNames}}" bindchange="onSectionChange">
          <view>{{profileForm.sectionLabel}}</view>
        </picker>
      </view>
      <view class="field">
        <view class="label">申请说明</view>
        <textarea value="{{profileForm.sectionNote}}" data-field="sectionNote" bindinput="onProfileInput" placeholder="如申请调整声部，请写一句原因"></textarea>
      </view>
      <button class="btn primary" bindtap="saveProfile">保存资料</button>
    </view>
  </view>

  <view class="section stats-grid">
    <view class="stat card">
      <view class="stat-num">{{stats.attendanceRate}}%</view>
      <view class="muted">出勤率</view>
    </view>
    <view class="stat card">
      <view class="stat-num">{{stats.records}}</view>
      <view class="muted">打卡记录</view>
    </view>
    <view class="stat card">
      <view class="stat-num">{{stats.feedback}}</view>
      <view class="muted">点评反馈</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">我的考勤</view>
    <view wx:for="{{attendance}}" wx:key="id" class="card">
      <view class="row">
        <view>
          <view class="card-title">{{item.eventTitle}}</view>
          <view class="card-subtitle">{{item.timeText}}</view>
        </view>
        <view class="pill {{item.status === '已签到' ? 'green' : 'gold'}}">{{item.status}}</view>
      </view>
      <view wx:if="{{item.note}}" class="muted note">{{item.note}}</view>
    </view>
    <view wx:if="{{!attendance.length}}" class="empty">暂无考勤记录</view>
  </view>

  <view class="section">
    <view class="section-title">我的打卡与点评</view>
    <view wx:for="{{records}}" wx:key="id" class="card">
      <view class="card-title">{{item.taskTitle}}</view>
      <view class="card-subtitle">{{item.submittedAtText}} · {{item.status}}</view>
      <view class="muted">音准：{{item.pitch || '未填'}} · 节奏：{{item.rhythm || '未填'}} · 气息：{{item.breath || '未填'}}</view>
      <view wx:if="{{item.feelings}}" class="note">练习感受：{{item.feelings}}</view>
      <view wx:if="{{item.feedback}}" class="feedback">点评：{{item.feedback}}</view>
      <view wx:else class="muted note">等待声部长/指挥点评</view>
    </view>
    <view wx:if="{{!records.length}}" class="empty">暂无打卡记录</view>
  </view>
</view>
