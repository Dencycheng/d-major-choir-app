.page {
  min-height: 100vh;
  background: #faf7ef;
  padding: 32rpx;
  box-sizing: border-box;
}

.hero {
  background: #111111;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  margin-bottom: 28rpx;
}

.hero-title {
  color: #c69f62;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-sub {
  color: #9e9e9e;
  font-size: 26rpx;
  margin-top: 12rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 24rpx rgba(17, 17, 17, 0.05);
}

.card.center {
  text-align: center;
  padding: 72rpx 36rpx;
}

.status-icon {
  font-size: 72rpx;
}

.status-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111111;
  margin-top: 20rpx;
}

.status-desc {
  font-size: 26rpx;
  color: #756f68;
  margin-top: 16rpx;
  line-height: 1.6;
}

.field {
  margin-bottom: 28rpx;
}

.label {
  font-size: 26rpx;
  color: #756f68;
  margin-bottom: 12rpx;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  background: #faf7ef;
  border: 2rpx solid #e8d5af;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #111111;
}

.textarea {
  height: 160rpx;
}

.picker.placeholder {
  color: #9e9e9e;
}

.btn-gold {
  margin-top: 24rpx;
  background: #c69f62;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-gold::after {
  border: none;
}
