<view class="page">
  <view class="hero">
    <view class="hero-title">{{member.name || '成员'}}，本周要做的事</view>
    <view class="hero-subtitle">{{choir.name}} · {{member.sectionLabel}}</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">最近排练</view>
      <button class="btn" size="mini" bindtap="goActivities">查看活动</button>
    </view>
    <view wx:if="{{latestEvent.id}}" class="card">
      <view class="row">
        <view>
          <view class="card-title">{{latestEvent.title}}</view>
          <view class="card-subtitle">{{latestEvent.time}} · {{latestEvent.location}}</view>
        </view>
        <view class="pill gold">{{latestEvent.myAttendance.status || '待反馈'}}</view>
      </view>
      <view class="btn-row">
        <button class="btn" data-id="{{latestEvent.id}}" data-response="参加" bindtap="respondEvent">参加</button>
        <button class="btn" data-id="{{latestEvent.id}}" data-response="请假" bindtap="respondEvent">请假</button>
        <button class="btn primary" data-id="{{latestEvent.id}}" bindtap="checkin">签到</button>
      </view>
    </view>
    <view wx:else class="empty">暂无排练活动</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">本周练习任务</view>
      <button class="btn" size="mini" bindtap="goPractice">去打卡</button>
    </view>
    <view wx:for="{{pendingTasks}}" wx:key="id" class="card">
      <view class="row">
        <view>
          <view class="card-title">{{item.title}}</view>
          <view class="card-subtitle">{{item.workTitle}} · 截止 {{item.deadline}}</view>
        </view>
        <view class="pill">{{item.progress.submitted}}/{{item.progress.required}}</view>
      </view>
      <view class="muted">{{item.brief}}</view>
    </view>
    <view wx:if="{{!pendingTasks.length}}" class="empty">当前没有待打卡任务</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">最新点评</view>
      <button class="btn" size="mini" bindtap="goMine">我的记录</button>
    </view>
    <view wx:if="{{latestFeedback.id}}" class="card">
      <view class="card-title">{{latestFeedback.taskTitle}}</view>
      <view class="card-subtitle">{{latestFeedback.status}} · {{latestFeedback.submittedAtText}}</view>
      <view class="feedback">{{latestFeedback.feedback}}</view>
    </view>
    <view wx:else class="empty">暂无新点评</view>
  </view>
</view>
