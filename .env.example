# Runtime
NODE_ENV=production
HOST=127.0.0.1
PORT=4173

# Public domains
API_ORIGIN=https://api.dmajorchoir.com
ADMIN_ORIGIN=https://admin.dmajorchoir.com

# Database
SQLITE_DB_PATH=data/dmajor.sqlite

# Auth
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
SESSION_COOKIE_NAME=dmajor_session
WECHAT_APP_ID=wx_CHANGE_ME
WECHAT_APP_SECRET=CHANGE_ME

# Object storage: current MVP uses local uploads; keep these for future COS/S3 migration.
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_REGION=ap-shanghai
OBJECT_STORAGE_BUCKET=dmajor-choir-private-prod
OBJECT_STORAGE_PRIVATE_BASE_URL=https://private-storage.example.com/dmajor
OBJECT_STORAGE_ACCESS_KEY_ID=CHANGE_ME
OBJECT_STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
FILE_SIGNING_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
SIGNED_URL_TTL_SECONDS=600

# Notifications
WECHAT_TEMPLATE_TASK_REMINDER=CHANGE_ME
WECHAT_TEMPLATE_FEEDBACK_READY=CHANGE_ME

# V2.1 正式账号体系
# 首个超级管理员（仅供 npm run create-admin 读取，禁止提交 Git）
ADMIN_EMAIL=
ADMIN_MOBILE=
ADMIN_PASSWORD=
# 会话有效期（小时），默认 336（14 天）
SESSION_TTL_HOURS=336
# 数据与代码分离（生产环境建议）
# SQLITE_DB_PATH=/home/ubuntu/d_major_runtime/data/dmajor.sqlite
# UPLOAD_DIR=/home/ubuntu/d_major_runtime/uploads
# BACKUP_DIR=/home/ubuntu/d_major_runtime/backups
