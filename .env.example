# Runtime
NODE_ENV=production
HOST=127.0.0.1
PORT=4173

# Public domains
API_ORIGIN=https://api.dmajorchoir.com
ADMIN_ORIGIN=https://admin.dmajorchoir.com

# Database
DATABASE_URL=postgres://dmajor_app:CHANGE_ME@127.0.0.1:5432/dmajor_choir
DATABASE_SSL=true

# Auth
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
SESSION_COOKIE_NAME=dmajor_session
WECHAT_APP_ID=wx_CHANGE_ME
WECHAT_APP_SECRET=CHANGE_ME

# Object storage: private bucket only
OBJECT_STORAGE_PROVIDER=s3
OBJECT_STORAGE_REGION=ap-east-1
OBJECT_STORAGE_BUCKET=dmajor-choir-private-prod
OBJECT_STORAGE_PRIVATE_BASE_URL=https://private-storage.example.com/dmajor
OBJECT_STORAGE_ACCESS_KEY_ID=CHANGE_ME
OBJECT_STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
FILE_SIGNING_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
SIGNED_URL_TTL_SECONDS=600

# Notifications
WECHAT_TEMPLATE_TASK_REMINDER=CHANGE_ME
WECHAT_TEMPLATE_FEEDBACK_READY=CHANGE_ME
